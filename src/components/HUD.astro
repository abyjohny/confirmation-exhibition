---
// Heads-up Display (HUD) including Scroll Progress Ring and Custom Cursor (Lumen)
---

<!-- Custom Cursor elements -->
<div id="lumen-pointer"></div>
<div id="lumen-glow"></div>

<!-- Progress scroll indicator -->
<div id="scroll-hud">
  <svg class="progress-ring" width="60" height="60">
    <circle 
      class="progress-ring__circle-bg" 
      stroke="rgba(255,255,255,0.05)" 
      stroke-width="2" 
      fill="transparent" 
      r="26" 
      cx="30" 
      cy="30"
    />
    <circle 
      class="progress-ring__circle" 
      stroke="#ffd700" 
      stroke-width="2" 
      fill="transparent" 
      r="26" 
      cx="30" 
      cy="30"
    />
  </svg>
  <span id="scroll-state-num">01</span>
</div>

<style>
  /* Custom Cursor (Lumen) styling */
  #lumen-pointer {
    position: fixed;
    width: 8px;
    height: 8px;
    background-color: #fffdf9;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 10px #ffd700, 0 0 20px #ffb400;
    will-change: transform, left, top;
  }

  #lumen-glow {
    position: fixed;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(255, 215, 0, 0.08) 0%, rgba(255, 215, 0, 0) 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    will-change: transform, left, top;
  }

  /* Progress Ring styling */
  #scroll-hud {
    position: fixed;
    bottom: 40px;
    right: 40px;
    width: 60px;
    height: 60px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
    pointer-events: none;
  }

  .progress-ring {
    position: absolute;
    transform: rotate(-90deg);
  }

  .progress-ring__circle {
    stroke-dasharray: 163.36; /* 2 * PI * r (r=26) */
    stroke-dashoffset: 163.36;
    transition: stroke-dashoffset 0.1s linear;
  }

  #scroll-state-num {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #ffd700;
    letter-spacing: 0.15em;
    margin-left: 2px;
  }
</style>
