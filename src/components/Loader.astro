---
// Cinematic preloader component for Astro
---

<div id="cinematic-loader" class="loader-container">
  <div class="loader-content">
    <div id="seed-of-light" class="seed-of-light"></div>
    <div id="loader-status-text" class="loader-status">Awakening Light...</div>
  </div>
</div>

<style>
  .loader-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #050505;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    font-family: 'Cinzel', serif;
    overflow: hidden;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .seed-of-light {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: #fffdf9;
    box-shadow: 
      0 0 20px #ffd700, 
      0 0 40px #ffb400, 
      0 0 80px #ffd700, 
      inset 0 0 4px rgba(255, 255, 255, 0.8);
    margin-bottom: 35px;
    transform: scale(1);
  }

  .loader-status {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5em;
    color: rgba(255, 253, 249, 0.45);
    text-transform: uppercase;
    text-align: center;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.08);
    transition: opacity 0.4s ease;
  }
</style>
