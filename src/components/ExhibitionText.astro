---
// Typographic layouts for the 6 exhibition states
---

<div id="text-overlays">
  <!-- State 1: Dormancy (Expectant Silence) -->
  <div class="overlay-state split-frame" id="state-1-dormancy">
    <div class="frame-left">
      <div class="intro-block">
        <span class="state-indicator">STATE 01 // DORMANCY</span>
        <h1 class="intro-title" aria-label="CONFIRMATION">CONFIRMATION</h1>
        <div class="editorial-divider"></div>
        <p class="intro-text">Scroll to awaken the lens.</p>
      </div>
    </div>
    <div class="frame-right"></div>
  </div>

  <!-- State 2: Awakening (The Optical Concept) -->
  <div class="overlay-state split-frame" id="state-2-awakening">
    <div class="frame-left">
      <div class="scripture-block">
        <span class="state-indicator">STATE 02 // AWAKENING</span>
        <h1 class="concept-title" aria-label="KALEIDOSCOPE">KALEIDOSCOPE</h1>
        <div class="editorial-divider"></div>
        <p class="concept-desc">A device through which we look at things from <span class="highlight-gold">many different angles</span> often with <span class="highlight-gold">SPECTACULAR RESULTS</span>.</p>
      </div>
    </div>
    <div class="frame-right"></div>
  </div>

  <!-- State 3: Recognition (The Soul Eye) -->
  <div class="overlay-state split-frame" id="state-3-recognition">
    <div class="frame-left">
      <div class="scripture-block">
        <span class="state-indicator">STATE 03 // RECOGNITION</span>
        <h1 class="concept-title" aria-label="SOUL EYE DO SCOPE">SOUL EYE DO SCOPE</h1>
        <div class="editorial-divider"></div>
        <p class="concept-desc">A device through which we look at things using the <span class="highlight-gold">Gifts of the Holy Spirit</span>. The Results are often <span class="highlight-gold">SPECTACULAR</span>.</p>
      </div>
    </div>
    <div class="frame-right"></div>
  </div>

  <!-- State 4: Alignment (The Spirit Descends) -->
  <div class="overlay-state centered-frame" id="state-4-alignment">
    <div class="spotlight-block">
      <span class="state-indicator">STATE 04 // ALIGNMENT</span>
      <p class="scripture-text">The Spirit descends to align the fragments of our sight.</p>
    </div>
  </div>

  <!-- State 5: Transformation (The Seven Gifts Birth) -->
  <div class="overlay-state centered-frame" id="state-5-transformation">
    <div class="gifts-block">
      <span class="state-indicator">STATE 05 // TRANSFORMATION</span>
      <h2 class="gifts-headline">WHAT ARE THE GIFTS OF THE HOLY SPIRIT?</h2>
      <div class="editorial-divider"></div>
      
      <!-- Horizontal row of gift nodes spreading outward -->
      <div class="gifts-row">
        <!-- Gift 1: Wisdom -->
        <div class="gift-node" data-gift="1" style="--offset-x: 330px;" id="node-wisdom">
          <div class="gift-num">1</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20M4 19.5V3.5A2.5 2.5 0 0 1 6.5 1H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5z"/>
            </svg>
          </div>
          <div class="gift-name">Wisdom</div>
        </div>

        <!-- Gift 2: Understanding -->
        <div class="gift-node" data-gift="2" style="--offset-x: 220px;" id="node-understanding">
          <div class="gift-num">2</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M9 21h6M12 18v3M12 2v2M4.22 4.22l1.42 1.42M1.5 12h2M19.78 4.22l-1.42 1.42M20.5 12h2M12 6a6 6 0 0 0-6 6c0 2.22 1.2 4.15 3 5.19V18h6v-0.81c1.8-1.04 3-2.97 3-5.19a6 6 0 0 0-6-6z"/>
            </svg>
          </div>
          <div class="gift-name">Understanding</div>
        </div>

        <!-- Gift 3: Right Judgement -->
        <div class="gift-node" data-gift="3" style="--offset-x: 110px;" id="node-judgement">
          <div class="gift-num">3</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M12 3v18M12 5l-8 2M12 5l8 2M4 7v10M20 7v10M2 17h4M18 17h4M12 21H6M12 21h6"/>
            </svg>
          </div>
          <div class="gift-name">Right Judgement</div>
        </div>

        <!-- Gift 4: Courage -->
        <div class="gift-node" data-gift="4" style="--offset-x: 0px;" id="node-courage">
          <div class="gift-num">4</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="gift-name">Courage</div>
        </div>

        <!-- Gift 5: Knowledge -->
        <div class="gift-node" data-gift="5" style="--offset-x: -110px;" id="node-knowledge">
          <div class="gift-num">5</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M12 22V14M12 14c-2-1-4-1-5-3s0-4 2-4M12 14c2-1 4-1 5-3s0-4-2-4M12 10V5M12 5c-1-1-2.5-1-3.5 0s0 2 1.5 2M12 5c1-1 2.5-1 3.5 0s0 2-1.5 2"/>
            </svg>
          </div>
          <div class="gift-name">Knowledge</div>
        </div>

        <!-- Gift 6: Piety -->
        <div class="gift-node" data-gift="6" style="--offset-x: -220px;" id="node-piety">
          <div class="gift-num">6</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 3v18M8 8h8"/>
            </svg>
          </div>
          <div class="gift-name">Piety</div>
        </div>

        <!-- Gift 7: Fear of the Lord -->
        <div class="gift-node" data-gift="7" style="--offset-x: -330px;" id="node-fear">
          <div class="gift-num">7</div>
          <div class="gift-icon-container">
            <svg class="gift-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 1.5 1 2.5 2 3.5s2.5 2 2.5 4.5a5.5 5.5 0 0 1-11 0c0-1.25.5-2 1-3 .5 1 1 2 1 3z"/>
            </svg>
          </div>
          <div class="gift-name">Fear of the Lord</div>
        </div>
      </div>

      <!-- Interactive Description Tray -->
      <div id="gift-description-tray">
        <p id="gift-desc-text">Hover or click a gift's icon above to reveal its vision-transforming power.</p>
      </div>
    </div>
  </div>

  <!-- State 6: Revelation (The Final Climax) -->
  <div class="overlay-state centered-frame" id="state-6-revelation">
    <div class="revelation-block">
      <span class="state-indicator">STATE 06 // REVELATION</span>
      <h1 class="revelation-headline" aria-label="Confirmation changes the way we see the world.">Confirmation changes the way we see the world.</h1>
      <h1 class="revelation-accent" aria-label="Not the world itself.">Not the world itself.</h1>
      <div class="revelation-divider"></div>
      <p class="revelation-footer">You are the light. The lens of grace is complete.</p>
    </div>
  </div>
</div>

<style>
  #text-overlays {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    pointer-events: none; /* Allow pointer events to fall through by default */
  }

  .overlay-state {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    will-change: opacity, transform;
  }

  /* Cinematic Composition Grid Layouts (Strict Protected Zones) */
  .split-frame {
    display: flex;
    width: 100%;
    height: 100%;
  }

  .frame-left {
    width: 44%; /* Expanded width for projector visual zone */
    max-width: 680px;
    min-width: 480px;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-left: 6%;
    padding-right: 2%;
    z-index: 11;
  }

  .frame-right {
    width: 56%; /* Rest of the screen remains empty for the canvas artwork */
    height: 100%;
    pointer-events: none;
  }

  .centered-frame {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  /* Common Typography Layout */
  .state-indicator {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.6em;
    color: rgba(255, 215, 0, 0.7); /* Boosted contrast for projectors */
    margin-bottom: 28px;
    display: block;
  }

  /* Fading Divider: Terminating elegantly in negative space */
  .editorial-divider {
    width: 180px;
    height: 2px; /* Thicker line for projection screen */
    background: linear-gradient(to right, rgba(255, 215, 0, 0.65), rgba(255, 215, 0, 0));
    margin-bottom: 30px;
  }

  .split-frame .editorial-divider {
    margin-left: 0;
    margin-right: auto;
  }

  /* Intro & Concept Layout */
  .intro-block, .scripture-block {
    width: 100%;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .intro-title, .concept-title {
    font-family: 'Cinzel', serif;
    font-size: 56px; /* Scaled up from 36px */
    font-weight: 400;
    letter-spacing: 0.22em;
    color: #fffdf9;
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.16);
    line-height: 1.25;
  }

  .intro-text, .concept-desc {
    font-family: 'Inter', sans-serif;
    font-size: 26px; /* Scaled up from 17px */
    line-height: 1.7;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: rgba(255, 253, 249, 0.85); /* Boosted opacity for projector contrast */
    margin-top: 15px;
  }

  .highlight-gold {
    color: #ffd700;
    font-weight: 600;
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.35);
    letter-spacing: 0.05em;
  }

  /* State 4 Spotlight layout (Lower Third Composition) */
  .spotlight-block {
    position: absolute;
    bottom: 10%; /* Generous breathing space below centered dove */
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    max-width: 960px; /* Expanded for larger text */
    padding: 0 40px;
  }

  .scripture-text {
    font-family: 'Cinzel', serif;
    font-size: 38px; /* Scaled up from 22px */
    line-height: 1.55;
    font-weight: 300;
    color: #fffdf9;
    text-shadow: 0 0 15px rgba(255, 253, 249, 0.3), 0 0 30px rgba(255, 215, 0, 0.2);
  }

  /* State 5: The Seven Gifts Panel */
  .gifts-block {
    width: 100%;
    max-width: 1200px; /* Expanded width */
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 40px;
    pointer-events: auto; /* Enable mouse events so row elements can be clicked/hovered */
  }

  .gifts-block .state-indicator {
    text-align: center;
  }

  .gifts-block .editorial-divider {
    background: linear-gradient(to right, rgba(255, 215, 0, 0), rgba(255, 215, 0, 0.65) 50%, rgba(255, 215, 0, 0));
    margin: 0 auto 30px auto;
  }

  .gifts-headline {
    font-family: 'Cinzel', serif;
    font-size: 34px; /* Scaled up from 20px */
    font-weight: 400;
    letter-spacing: 0.2em;
    color: #fffdf9;
    text-align: center;
    text-shadow: 0 0 15px rgba(255,255,255,0.12);
  }

  .gifts-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    max-width: 1100px; /* Expanded width to give nodes more room */
    margin: 50px auto 0 auto;
  }

  /* Gift nodes transition spreading out from center */
  .gift-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 140px; /* Expanded node width from 110px */
    opacity: 0;
    transform: translate(var(--offset-x), 0) scale(0);
    transition: transform 1.8s cubic-bezier(0.2, 1, 0.25, 1), opacity 1.8s ease;
    cursor: pointer;
  }

  /* Spread active transition */
  .gift-node.active {
    opacity: 0.35;
    transform: translate(0, 0) scale(1);
  }

  .gift-node.active:hover,
  .gift-node.active-hover {
    opacity: 1;
    transform: scale(1.08);
  }

  .gift-num {
    font-family: 'Cinzel', serif;
    font-size: 20px; /* Scaled up from 13px */
    font-weight: 600;
    color: #ffd700;
    margin-bottom: 10px;
    text-shadow: 0 0 8px rgba(255,215,0,0.3);
  }

  .gift-icon-container {
    width: 84px; /* Scaled up from 60px */
    height: 84px; /* Scaled up from 60px */
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background-color: rgba(255, 255, 255, 0.02);
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 16px;
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8);
    transition: border 0.5s, background-color 0.5s, box-shadow 0.5s;
  }

  .gift-node:hover .gift-icon-container,
  .gift-node.active-hover .gift-icon-container {
    border: 1px solid #ffd700;
    background-color: rgba(255, 215, 0, 0.05);
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.2), inset 0 0 10px rgba(255, 215, 0, 0.1);
  }

  .gift-svg {
    width: 36px; /* Scaled up from 26px */
    height: 36px; /* Scaled up from 26px */
    color: rgba(255, 253, 249, 0.65);
    transition: color 0.5s, transform 0.5s;
  }

  .gift-node:hover .gift-svg,
  .gift-node.active-hover .gift-svg {
    color: #ffd700;
    transform: scale(1.1);
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.5));
  }

  .gift-name {
    font-family: 'Inter', sans-serif;
    font-size: 14px; /* Scaled up from 10px */
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    line-height: 1.3;
    transition: color 0.5s;
  }

  .gift-node:hover .gift-name,
  .gift-node.active-hover .gift-name {
    color: #fffdf9;
  }

  #gift-description-tray {
    width: 100%;
    max-width: 850px; /* Expanded tray width */
    margin-top: 50px;
    text-align: center;
    min-height: 80px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 20px;
  }

  #gift-desc-text {
    font-family: 'Inter', sans-serif;
    font-size: 24px; /* Scaled up from 16px */
    line-height: 1.65;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: rgba(255, 253, 249, 0.85); /* Boosted contrast for projector screen */
    transition: opacity 0.3s ease;
  }

  /* State 6: Revelation block */
  .revelation-block {
    text-align: center;
    max-width: 1000px; /* Expanded width */
    padding: 0 40px;
  }

  .revelation-headline {
    font-family: 'Cinzel', serif;
    font-size: 54px; /* Scaled up from 34px */
    line-height: 1.45;
    font-weight: 300;
    color: #fffdf9;
    margin-bottom: 15px;
    text-shadow: 0 0 20px rgba(255,255,255,0.2);
  }

  .revelation-accent {
    font-family: 'Cinzel', serif;
    font-size: 64px; /* Scaled up from 40px */
    font-weight: 700;
    color: #ffd700;
    letter-spacing: 0.05em;
    text-shadow: 0 0 35px rgba(255, 215, 0, 0.55);
    margin-bottom: 40px;
  }

  .revelation-divider {
    width: 120px; /* Expanded divider line */
    height: 2px;
    background-color: rgba(255, 215, 0, 0.45);
    margin: 0 auto 30px auto;
  }

  .revelation-footer {
    font-family: 'Inter', sans-serif;
    font-size: 18px; /* Scaled up from 12px */
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 253, 249, 0.75);
  }

  /* State 6: Wisdom Narrative (Journey of Wisdom) */
  #state-6-wisdom {
    pointer-events: none;
  }

  .wisdom-narrative-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }



  /* Mobile Responsiveness */
  @media (max-width: 900px) {
    .split-frame {
      flex-direction: column;
    }
    
    .frame-left {
      width: 100%;
      max-width: 100%;
      height: 45%;
      padding-left: 6%;
      padding-right: 6%;
      padding-top: 8%;
      align-items: center;
      text-align: center;
    }
    
    .split-frame .editorial-divider {
      margin-left: auto;
      margin-right: auto;
    }
    
    .intro-block, .scripture-block {
      align-items: center;
      text-align: center;
    }
    
    .frame-right {
      width: 100%;
      height: 55%;
    }
    
    .gifts-row {
      flex-wrap: wrap;
      justify-content: center;
      gap: 15px 25px;
    }
    
    .gift-node {
      width: 90px;
      transform: translate(0, 0) scale(1) !important; /* Disable translations on mobile */
    }
    
    .gift-icon-container {
      width: 50px;
      height: 50px;
    }
    
    .gift-svg {
      width: 22px;
      height: 22px;
    }
    
    .gifts-headline {
      font-size: 16px;
    }
    
    .revelation-headline {
      font-size: 26px;
    }
    
    .revelation-accent {
      font-size: 30px;
    }
  }
</style>
