---
import Loader from '../components/Loader.astro';
import HUD from '../components/HUD.astro';
import ExhibitionText from '../components/ExhibitionText.astro';

// Production Interactive Digital Exhibition Page
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Kaleidoscope of Confirmation — Interactive Digital Exhibition</title>
  <meta name="description" content="An interactive, cinematic digital exhibition exploring the metaphor of the Kaleidoscope and the Seven Gifts of the Holy Spirit.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@300;400;500;600;700;900&family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Main WebGL Rendering Canvas -->
  <div id="canvas-container">
    <canvas id="exhibition-canvas"></canvas>
  </div>

  <!-- Cinematic HTML UI Components -->
  <Loader />
  <HUD />
  <ExhibitionText />

  <!-- Scroll trigger heights (Forces body scroll height for ScrollTrigger) -->
  <div class="scroll-container"></div>

  <script>
    console.log("EXHIBITION SCRIPT BOOTED");
    import { AssetLoader } from '../renderer/AssetLoader';
    import { Renderer } from '../renderer/Renderer';
    import { SceneController } from '../controllers/SceneController';
    import { ScrollController } from '../controllers/ScrollController';
    import { gsap } from 'gsap';

    // Import optimized artwork paths via Astro Vite resolver
    import kaleidoscopeUrl from '../assets/artwork/exhibit_kaleidoscope.png';
    import soulEyeUrl from '../assets/artwork/exhibit_soul_eye.png';
    import doveUrl from '../assets/artwork/exhibit_dove.png';

    const GIFT_DESCRIPTIONS: Record<string, string> = {
      "1": "Allows us to see things as God sees them, understanding the true value of life's experiences.",
      "2": "Gives us a deeper insight into the truths of faith, helping us to grasp the meaning of God's Word.",
      "3": "Helps us to make correct, moral choices in everyday situations, guided by the Holy Spirit.",
      "4": "Strengthens us to stand up for our faith and face difficulties with fortitude and trust in God.",
      "5": "Enables us to recognize the hand of God at work in our lives and the beauty of creation.",
      "6": "Inspires us to love God as our Father and show deep reverence for all sacred things and others.",
      "7": "Fills us with a sacred awe and wonder of God's presence, leading us to respect His love and avoid sin."
    };

    let sceneController: SceneController;
    let scrollController: ScrollController;
    let renderer: Renderer;

    // Boot up the Cinematic Loader and Preload assets
    const loader = new AssetLoader({
      kaleidoscope: (kaleidoscopeUrl as any).src || kaleidoscopeUrl,
      soulEye: (soulEyeUrl as any).src || soulEyeUrl,
      dove: (doveUrl as any).src || doveUrl
    });

    const statusText = document.getElementById('loader-status-text')!;
    const seed = document.getElementById('seed-of-light')!;

    loader.onProgress((progress) => {
      // Step through narration stages
      if (progress < 0.25) {
        statusText.innerText = "Awakening Light...";
      } else if (progress < 0.5) {
        statusText.innerText = "Aligning Patterns...";
      } else if (progress < 0.75) {
        statusText.innerText = "Revealing Reflection...";
      } else if (progress < 1.0) {
        statusText.innerText = "Opening Portal...";
      }
    });

    loader.onComplete(() => {
      statusText.innerText = "Experience Begins";
      
      // Initialize engines
      const canvas = document.getElementById('exhibition-canvas') as HTMLCanvasElement;
      
      try {
        console.log("Exhibition: Initializing Renderer...");
        renderer = new Renderer(canvas, loader);
        console.log("Exhibition: Renderer initialized successfully!");

        console.log("Exhibition: Initializing SceneController...");
        sceneController = new SceneController();
        sceneController.setRenderer(renderer);
        console.log("Exhibition: SceneController initialized!");
        
        // Setup HUD progress mapping
        const hudCircle = document.querySelector('.progress-ring__circle') as SVGCircleElement;
        const hudNum = document.getElementById('scroll-state-num')!;
        const circumference = 163.36;

        sceneController.registerSceneChangeListener((sceneNum) => {
          hudNum.innerText = `0${sceneNum}`;
          
          // Custom interactions for state 5 elements (Sequential node pop-in)
          const giftNodes = document.querySelectorAll('.gift-node');
          if (sceneNum === 5) {
            giftNodes.forEach((node, idx) => {
              gsap.delayedCall(idx * 0.1, () => {
                if (sceneController.state.activeScene === 5) {
                  node.classList.add('active');
                }
              });
            });
          } else {
            giftNodes.forEach(node => node.classList.remove('active'));
          }
        });

        // Setup ticking functions for Progress HUD
        gsap.ticker.add(() => {
          const progressFraction = sceneController.state.scrollProgress / 6.0;
          const offset = circumference - progressFraction * circumference;
          hudCircle.style.strokeDashoffset = offset.toString();
        });

        // Initialize Scroll drives (Lenis + GSAP timeline)
        console.log("Exhibition: Initializing ScrollController...");
        scrollController = new ScrollController(sceneController);
        console.log("Exhibition: ScrollController initialized!");

        // Bind interactive gift hovers
        setupGiftHovers();

        // 3. Trigger cinematic entrance transition
        console.log("Exhibition: Creating entrance GSAP timeline...");
        const tl = gsap.timeline({
          onStart: () => console.log("Exhibition: Entrance timeline started!"),
          onComplete: () => {
            console.log("Exhibition: Entrance timeline completed! Hiding loader...");
            // Hide preloader overlay completely
            gsap.set('#cinematic-loader', { display: 'none' });
            
            // Enable rendering loop and inputs
            sceneController.state.loading = false;
            sceneController.startLoop();
            console.log("Exhibition: Render loop active!");
          }
        });

        tl.to(seed, {
          scale: 110,
          opacity: 0,
          duration: 1.5,
          ease: 'power3.inOut'
        })
        .to('#cinematic-loader', {
          opacity: 0,
          duration: 1.2,
          ease: 'power2.out'
        }, 0.3);

      } catch (err) {
        console.error("Renderer initialization failed:", err);
        statusText.innerText = "Fatal: WebGL unsupported.";
      }
    });

    // Interactive Gift Nodes logic
    function setupGiftHovers() {
      const giftNodes = document.querySelectorAll('.gift-node');
      const descText = document.getElementById('gift-desc-text')!;
      
      giftNodes.forEach(node => {
        const giftId = node.getAttribute('data-gift')!;
        const showDesc = () => {
          giftNodes.forEach(n => n.classList.remove('active-hover'));
          node.classList.add('active-hover');

          gsap.to(descText, {
            opacity: 0,
            duration: 0.15,
            onComplete: () => {
              descText.innerText = GIFT_DESCRIPTIONS[giftId];
              gsap.to(descText, { opacity: 1, duration: 0.25 });
            }
          });
        };

        node.addEventListener('mouseenter', showDesc);
        node.addEventListener('click', showDesc);
      });

      document.querySelector('.gifts-row')!.addEventListener('mouseleave', () => {
        giftNodes.forEach(n => n.classList.remove('active-hover'));
        gsap.to(descText, {
          opacity: 0,
          duration: 0.15,
          onComplete: () => {
            descText.innerText = "Hover or click a gift's icon above to reveal its vision-transforming power.";
            gsap.to(descText, { opacity: 1, duration: 0.25 });
          }
        });
      });
    }

    // High performance cursor positioning (GSAP quickTo)
    if (typeof window !== 'undefined') {
      const xTo = gsap.quickTo('#lumen-pointer', 'left', { duration: 0.08, ease: 'power2.out' });
      const yTo = gsap.quickTo('#lumen-pointer', 'top', { duration: 0.08, ease: 'power2.out' });
      const gxTo = gsap.quickTo('#lumen-glow', 'left', { duration: 0.16, ease: 'power2.out' });
      const gyTo = gsap.quickTo('#lumen-glow', 'top', { duration: 0.16, ease: 'power2.out' });

      window.addEventListener('mousemove', (e) => {
        xTo(e.clientX);
        yTo(e.clientY);
        gxTo(e.clientX);
        gyTo(e.clientY);
      }, { passive: true });

      // Handle window resize updates
      window.addEventListener('resize', () => {
        if (renderer) renderer.resize();
        if (scrollController) scrollController.updateResize();
      }, { passive: true });
    }
  </script>
</body>
</html>

<style is:global>
  /* Custom global resets and aesthetics */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body, html {
    width: 100%;
    min-height: 100%;
    height: auto;
    overflow-x: hidden;
    background-color: #050505;
    font-family: 'Inter', sans-serif;
    color: #fffdf9;
    cursor: none; /* Hide standard cursor for the custom Lumen dot */
    -webkit-user-select: none;
    user-select: none;
    /* Hide scrollbar for IE, Edge and Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  body::-webkit-scrollbar, html::-webkit-scrollbar {
    display: none;
  }

  /* Canvas layout */
  #canvas-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  #exhibition-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Scroll height driver */
  .scroll-container {
    position: relative;
    width: 100%;
    height: 700vh; /* 7 state scrolls */
    pointer-events: none;
    z-index: 2;
  }
</style>
